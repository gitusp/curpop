{
  "title": "Cursor Highlight",
  "rules": [
    {
      "description": "Left Control -> highlight cursor (use Right Control as modifier)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_control"
          },
          "to": [
            { "shell_command": "~/.local/bin/highlight" }
          ]
        }
      ]
    }
  ]
}
